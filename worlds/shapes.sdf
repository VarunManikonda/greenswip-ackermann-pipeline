<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="interview_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Plugins updated from Ignition Fortress (libignition-*) to
         Gazebo Harmonic (gz-sim-*). Also added the missing
         sensors plugin — without it, the camera sensor in the URDF
         is silently ignored and /camera/image never publishes. -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- TARGET: red box. Color, shape, and dimensions all distinguish
         it from the decoys for the perception pipeline. -->
    <model name="target_box">
      <pose>3.0 -1.5 0.15 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.3 0.3 0.3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <material>
            <ambient>0.8 0.1 0.1 1</ambient>
            <diffuse>0.9 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- DECOY 1: blue sphere -->
    <model name="decoy_sphere">
      <pose>3.0 -0.7 0.2 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><sphere><radius>0.2</radius></sphere></geometry></collision>
        <visual name="vis">
          <geometry><sphere><radius>0.2</radius></sphere></geometry>
          <material>
            <ambient>0.1 0.1 0.8 1</ambient>
            <diffuse>0.1 0.1 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- DECOY 2: orange capsule -->
    <model name="decoy_capsule">
      <pose>3.0 0.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><capsule><radius>0.1</radius><length>0.30</length></capsule></geometry></collision>
        <visual name="vis">
          <geometry><capsule><radius>0.1</radius><length>0.30</length></capsule></geometry>
          <material>
            <ambient>1.0 0.5 0.0 1</ambient>
            <diffuse>1.0 0.5 0.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- DECOY 3: green cylinder -->
    <model name="decoy_cylinder">
      <pose>3.0 0.7 0.15 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><cylinder><radius>0.1</radius><length>0.30</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.1</radius><length>0.30</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.8 0.1 1</ambient>
            <diffuse>0.1 0.9 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
