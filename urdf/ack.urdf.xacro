<?xml version="1.0" encoding="utf-8"?>
<robot name="ackerman_simple" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--  BASE  -->
  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0.0115 0 0.0687" rpy="0 0 0" />
      <mass value="1.8886" />
      <inertia ixx="0.00576" ixy="0.0" ixz="0.000003" iyy="0.01878" iyz="0.0" izz="0.02437" />
    </inertial>
    <visual>
      <origin xyz="0.01 0 0.05" rpy="0 0 0" />
      <geometry><box size="0.35 0.15 0.08"/></geometry>
      <material name="blue"><color rgba="0.2 0.2 0.8 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.05" rpy="0 0 0" />
      <geometry><box size="0.35 0.15 0.08"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <origin xyz="-0.0117 0 0.02677" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="base_link" />
  </joint>

  <!--  FRONT LEFT STEERING & WHEEL  -->
  <link name="FL_STEERING_LINK">
    <inertial>
      <origin xyz="-0.0029 0 0" rpy="0 0 0" />
      <mass value="0.0038" />
      <inertia ixx="0.0000003" ixy="0" ixz="0" iyy="0.0000006" iyz="0" izz="0.0000003" />
    </inertial>
  </link>

  <joint name="FL_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 0.085 0.0235" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="FL_STEERING_LINK" />
    <axis xyz="0 0 1" />
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3" />
  </joint>

  <link name="FL_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0635" />
      <inertia ixx="0.000046" ixy="0" ixz="0" iyy="0.000089" iyz="0" izz="0.000046" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="FL_WHEEL_JOINT" type="continuous">
    <origin xyz="0 0.0245 0" rpy="0 0 0" />
    <parent link="FL_STEERING_LINK" />
    <child link="FL_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!--  FRONT RIGHT STEERING & WHEEL  -->
  <!-- NOTE: removed <mimic> tag from original. Ackermann plugin commands
       both steering joints independently. -->
  <link name="FR_STEERING_LINK">
    <inertial>
      <origin xyz="0.0015 0 0" rpy="0 0 0" />
      <mass value="0.0047" />
      <inertia ixx="0.0000003" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.0000007" />
    </inertial>
  </link>

  <joint name="FR_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 -0.085 0.0235" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="FR_STEERING_LINK" />
    <axis xyz="0 0 1" />
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3" />
  </joint>

  <link name="FR_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0635" />
      <inertia ixx="0.000046" ixy="0" ixz="0" iyy="0.000089" iyz="0" izz="0.000046" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="FR_WHEEL_JOINT" type="continuous">
    <origin xyz="0 -0.0245 0" rpy="0 0 0" />
    <parent link="FR_STEERING_LINK" />
    <child link="FR_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!--  REAR LEFT WHEEL  -->
  <link name="BL_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0616" />
      <inertia ixx="0.000046" ixy="0" ixz="0" iyy="0.000089" iyz="0" izz="0.000046" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="BL_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 0.1093 0.02075" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="BL_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!--  REAR RIGHT WHEEL  -->
  <link name="BR_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0616" />
      <inertia ixx="0.000046" ixy="0" ixz="0" iyy="0.000089" iyz="0" izz="0.000046" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="BR_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 -0.1093 0.02075" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="BR_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- CAMERA  -->
  <link name="CAMERA_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0548" />
      <inertia ixx="0.000069" ixy="0" ixz="0" iyy="0.000004" iyz="0" izz="0.000066" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.02 0.06 0.02"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.02 0.06 0.02"/></geometry>
    </collision>
  </link>

  <joint name="CAMERA_JOINT" type="fixed">
    <origin xyz="0.15 0.0 0.2" rpy="0 0.1 0" />
    <parent link="base_link" />
    <child link="CAMERA_LINK" />
  </joint>

  <!-- Optical frame: rotated so +Z points OUT of the lens.
       Required by REP-103 cameras convention. -->
  <joint name="CAMERA_OPTICAL_JOINT" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
    <parent link="CAMERA_LINK" />
    <child link="CAMERA_LINK_OPTICAL" />
  </joint>
  <link name="CAMERA_LINK_OPTICAL"/>

  <!--  GAZEBO PLUGINS — added to make the robot functional. -->

  <!-- Surface friction tweaks for grip -->
  <gazebo reference="FL_WHEEL_LINK"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="FR_WHEEL_LINK"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="BL_WHEEL_LINK"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="BR_WHEEL_LINK"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>

  <!-- Ackermann steering system. Subscribes to a Twist on /cmd_vel and
       converts (linear.x, angular.z) into rear wheel velocities and
       front steering angles using the wheelbase and kingpin width. -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>BL_WHEEL_JOINT</left_joint>
      <right_joint>BR_WHEEL_JOINT</right_joint>
      <left_steering_joint>FL_STEERING_JOINT</left_steering_joint>
      <right_steering_joint>FR_STEERING_JOINT</right_steering_joint>
      <kingpin_width>0.17</kingpin_width>
      <steering_limit>0.524</steering_limit>
      <wheel_base>0.295</wheel_base>
      <wheel_separation>0.2186</wheel_separation>
      <wheel_radius>0.05027</wheel_radius>
      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-2.0</min_acceleration>
      <max_acceleration>2.0</max_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Joint state publisher: publishes /joint_states so RViz can render
       wheel rotation correctly. -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- Camera sensor. Topic prefix 'camera' produces /camera/image and
       /camera/camera_info. The gz_frame_id MUST be the optical frame so
       images come out tagged correctly. -->
  <gazebo reference="CAMERA_LINK">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <topic>camera/image</topic>
      <gz_frame_id>CAMERA_LINK_OPTICAL</gz_frame_id>
      <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>15.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

</robot>
